{
  "name": "rednoise",
  "version": "0.1.1",
  "description": "WebAssembly build of the RedNoise CPU software renderer (wireframe, rasteriser, ray tracer, path tracer).",
  "type": "module",
  "license": "MIT",
  "main": "index.js",
  "module": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "dist/"
  ],
  "scripts": {
    "build": "bash build.sh"
  },
  "keywords": [
    "renderer",
    "ray-tracing",
    "wasm",
    "webassembly",
    "graphics"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ReverseZoom2151/rednoise"
  },
  "engines": {
    "node": ">=18"
  }
}
