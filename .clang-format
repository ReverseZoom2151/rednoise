# Matches the existing style: tabs for indentation, Allman-ish braces kept compact.
BasedOnStyle: LLVM
UseTab: ForIndentation
TabWidth: 4
IndentWidth: 4
ColumnLimit: 120
AccessModifierOffset: -4
PointerAlignment: Right
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: false
SortIncludes: false
